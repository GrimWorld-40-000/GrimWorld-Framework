<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <HediffDef ParentName="DiseaseBase">
        <defName>IndoctrinationChamberSickness</defName>
        <label>indoctrination sickness</label>
        <description>placeholder.</description>
        <descriptionShort>After-effects of indoctrination including dizziness, nausea, and vomiting.</descriptionShort>
        <makesSickThought>true</makesSickThought>
        <scenarioCanAdd>true</scenarioCanAdd>
        <comps>
          <li Class="HediffCompProperties_Disappears">
            <disappearsAfterTicks>8000~12000</disappearsAfterTicks>
            <showRemainingTime>true</showRemainingTime>
          </li>
        </comps>
        <stages>
          <li>
            <vomitMtbDays>0.125</vomitMtbDays>
            <capMods>
              <li>
                <capacity>Consciousness</capacity>
                <postFactor>0.8</postFactor>
              </li>
              <li>
                <capacity>Moving</capacity>
                <postFactor>0.9</postFactor>
              </li>
              <li>
                <capacity>Manipulation</capacity>
                <postFactor>0.9</postFactor>
              </li>
            </capMods>
          </li>
        </stages>
    </HediffDef>

    <HediffDef>
        <defName>GW_PersonaDisso</defName>
        <label>persona dissociation</label>
        <description>The subject's identity is fracturing. They often forget who they are or where they are going.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <stages>
            <li>
                <mentalStateGivers>
                    <li>
                        <mentalState>WanderConfused</mentalState>
                        <mtbDays>5</mtbDays>
                    </li>
                </mentalStateGivers>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.15</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>
</Defs>
